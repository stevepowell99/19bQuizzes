#!/bin/sh
# Delete Explorer-generated desktop.ini under the repo before commit (matches theorymaker; excludes .git).
# Enable hooks (once per clone): git config core.hooksPath .githooks
set -eu

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

COUNT="$(find "$ROOT" \( -path "$ROOT/.git" -o -path "$ROOT/.obsidian" \) -prune -o -type f -iname 'desktop.ini' -print | wc -l | tr -d '[:space:]')"
if [ "${COUNT:-0}" != "0" ]; then
  # -delete implies -depth and conflicts with -prune on Git for Windows/find; rm via -exec is fine.
  find "$ROOT" \( -path "$ROOT/.git" -o -path "$ROOT/.obsidian" \) -prune -o -type f -iname 'desktop.ini' -exec rm -f {} +
  git add -u >/dev/null 2>&1
  echo "pre-commit: deleted ${COUNT} desktop.ini file(s)"
fi

exit 0
